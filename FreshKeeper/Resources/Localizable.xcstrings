{
  "sourceLanguage" : "ja",
  "strings" : {
    "" : {

    },
    "〜 %@" : {
      "comment" : "A text view displaying the expiry date of a food item.",
      "isCommentAutoGenerated" : true
    },
    "%@, %@, %@, %@" : {
      "comment" : "A card view displaying information about a food item, including its name, storage location, expiry date, and a label indicating the remaining time until expiry.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "%1$@, %2$@, %3$@, %4$@"
          }
        }
      }
    },
    "%lld" : {
      "comment" : "A text field displaying the quantity of an item. The text field is bound to a `@State` property in the view.",
      "isCommentAutoGenerated" : true
    },
    "%lld:00" : {
      "comment" : "A picker option that shows an hour of the day.",
      "isCommentAutoGenerated" : true
    },
    "%lld%@" : {
      "comment" : "A label displaying a count of items, suffixed with the word \"item\" or \"items\" based on the count. The argument is the count of items. The argument is the string “unit.items”.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "%1$lld%2$@"
          }
        }
      }
    },
    "%lld%%" : {
      "comment" : "A label displaying the percentage of meals that have been consumed compared to those that have been discarded in a given month.",
      "isCommentAutoGenerated" : true
    },
    "¥%@" : {
      "comment" : "A large title displaying the total savings amount.",
      "isCommentAutoGenerated" : true
    },
    "¥%lld" : {
      "comment" : "A text view displaying the amount in yen for a given value. The argument is the amount to be displayed.",
      "isCommentAutoGenerated" : true
    },
    "1.0.0" : {
      "comment" : "The version number of the app.",
      "isCommentAutoGenerated" : true
    },
    "accessibility.decrease_quantity" : {
      "comment" : "A description of an accessibility label for decreasing the quantity of an item.",
